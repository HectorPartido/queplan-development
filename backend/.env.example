# ============================================================
# QUEPLAN - Variables de Entorno
# ============================================================
# Copia este archivo como .env y reemplaza los valores:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# SERVIDOR
# ------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ------------------------------------------------------------
# BASE DE DATOS MYSQL
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=queplan
DB_USER=root
DB_PASSWORD=tu_contraseña_mysql

# ------------------------------------------------------------
# JWT (Autenticación)
# ------------------------------------------------------------
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_segura
JWT_EXPIRES_IN=30d

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
FRONTEND_URL=http://127.0.0.1:5500

# ------------------------------------------------------------
# GMAIL SMTP (Recuperación de contraseña)
# ------------------------------------------------------------
# Necesitas una "contraseña de aplicación" de Google:
# 1. Activa verificación en 2 pasos: https://myaccount.google.com/security
# 2. Genera contraseña de app: https://myaccount.google.com/apppasswords
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
